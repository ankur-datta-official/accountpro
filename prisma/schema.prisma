// Prisma maps the existing Supabase public schema.
// Keep Supabase Auth and Storage operations in Supabase SDK; use Prisma only on server code.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String               @unique
  plan       String?              @default("starter")
  maxClients Int?                 @default(5) @map("max_clients")
  logoUrl    String?              @map("logo_url")
  address    String?
  phone      String?
  email      String?
  createdAt  DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime?            @default(now()) @map("updated_at") @db.Timestamptz(6)
  isActive   Boolean?             @default(true) @map("is_active")
  members    OrganizationMember[]
  clients    Client[]

  @@map("organizations")
}

model OrganizationMember {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String?       @map("org_id") @db.Uuid
  userId            String?       @map("user_id") @db.Uuid
  role              String        @default("accountant")
  isActive          Boolean?      @default(true) @map("is_active")
  invitedBy         String?       @map("invited_by") @db.Uuid
  createdAt         DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  invitedEmail      String?       @map("invited_email")
  invitationMessage String?       @map("invitation_message")
  organization      Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId, isActive], map: "idx_organization_members_org_id_active")
  @@index([invitedEmail], map: "idx_organization_members_invited_email")
  @@map("organization_members")
}

model Client {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                String?                 @map("org_id") @db.Uuid
  name                   String
  type                   String?                 @default("company")
  tradeName              String?                 @map("trade_name")
  bin                    String?
  tin                    String?
  address                String?
  phone                  String?
  email                  String?
  fiscalYearStart         Int?                   @default(7) @map("fiscal_year_start")
  isActive               Boolean?                @default(true) @map("is_active")
  createdAt              DateTime?               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime?               @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization           Organization?         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fiscalYears            FiscalYear[]
  accountHeads          AccountHead[]
  paymentModes          PaymentMode[]
  vouchers              Voucher[]
  voucherAttachments     VoucherAttachment[]
  payrollEmployees      PayrollEmployee[]
  payrollSalaryStructures PayrollSalaryStructure[]
  payrollRuns          PayrollRun[]
  payrollAccountMappings PayrollAccountMapping[]
  payrollPolicy         PayrollPolicy?

  @@map("clients")
}

model FiscalYear {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String?      @map("client_id") @db.Uuid
  label       String
  startDate   DateTime     @map("start_date") @db.Date
  endDate     DateTime     @map("end_date") @db.Date
  isActive    Boolean?     @default(false) @map("is_active")
  isClosed    Boolean?     @default(false) @map("is_closed")
  createdAt   DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vouchers    Voucher[]
  payrollRuns PayrollRun[]

  @@map("fiscal_years")
}

model AccountHead {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId               String?                 @map("client_id") @db.Uuid
  parentId               String?                 @map("parent_id") @db.Uuid
  name                   String
  type                   String?                 @map("type") // "expense", "income", "asset", "liability" (only for root nodes)
  openingBalance         Decimal?                @default(0) @map("opening_balance") @db.Decimal(15, 2)
  balanceType            String?                 @default("debit") @map("balance_type")
  isActive               Boolean?                @default(true) @map("is_active")
  sortOrder              Int?                    @default(0) @map("sort_order")
  createdAt              DateTime?               @default(now()) @map("created_at") @db.Timestamptz(6)
  client                 Client?                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent                 AccountHead?            @relation("AccountHeadHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children               AccountHead[]           @relation("AccountHeadHierarchy")
  voucherEntries         VoucherEntry[]
  payrollAccountMappings PayrollAccountMapping[]

  @@index([clientId], map: "idx_account_heads_client")
  @@index([parentId], map: "idx_account_heads_parent")
  @@map("account_heads")
}

model PaymentMode {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String?   @map("client_id") @db.Uuid
  name      String
  type      String?   @default("bank")
  accountNo String?   @map("account_no")
  isActive  Boolean?  @default(true) @map("is_active")
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vouchers  Voucher[]

  @@map("payment_modes")
}

model Voucher {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId           String?             @map("client_id") @db.Uuid
  fiscalYearId       String?             @map("fiscal_year_id") @db.Uuid
  voucherNo          Int                 @map("voucher_no")
  voucherDate        DateTime            @map("voucher_date") @db.Date
  voucherType        String              @map("voucher_type")
  paymentModeId      String?             @map("payment_mode_id") @db.Uuid
  description        String?
  monthLabel         String?             @map("month_label")
  isPosted           Boolean?            @default(true) @map("is_posted")
  createdBy          String?             @map("created_by") @db.Uuid
  createdAt          DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime?           @default(now()) @map("updated_at") @db.Timestamptz(6)
  client             Client?             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fiscalYear         FiscalYear?         @relation(fields: [fiscalYearId], references: [id])
  paymentMode        PaymentMode?        @relation(fields: [paymentModeId], references: [id])
  entries            VoucherEntry[]
  attachments        VoucherAttachment[]
  payrollAccrualRuns PayrollRun[]        @relation("PayrollAccrualVoucher")
  payrollPaymentRuns PayrollRun[]        @relation("PayrollPaymentVoucher")

  @@unique([clientId, fiscalYearId, voucherNo])
  @@index([clientId, voucherDate], map: "idx_vouchers_client_date")
  @@index([clientId, fiscalYearId], map: "idx_vouchers_client_fy")
  @@map("vouchers")
}

model VoucherEntry {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  voucherId     String?      @map("voucher_id") @db.Uuid
  accountHeadId String?      @map("account_head_id") @db.Uuid
  accountsGroup String?      @map("accounts_group")
  debit         Decimal?     @default(0) @db.Decimal(15, 2)
  credit        Decimal?     @default(0) @db.Decimal(15, 2)
  description   String?
  createdAt     DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  voucher       Voucher?     @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  accountHead   AccountHead? @relation(fields: [accountHeadId], references: [id])

  @@index([voucherId], map: "idx_voucher_entries_voucher")
  @@index([accountHeadId], map: "idx_voucher_entries_account")
  @@map("voucher_entries")
}

model VoucherAttachment {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  voucherId  String    @map("voucher_id") @db.Uuid
  clientId   String    @map("client_id") @db.Uuid
  fileName   String    @map("file_name")
  filePath   String    @unique @map("file_path")
  fileSize   BigInt    @map("file_size")
  mimeType   String?   @map("mime_type")
  uploadedBy String?   @map("uploaded_by") @db.Uuid
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  voucher    Voucher   @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([voucherId], map: "idx_voucher_attachments_voucher")
  @@index([clientId], map: "idx_voucher_attachments_client")
  @@map("voucher_attachments")
}

model PayrollEmployee {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId         String                   @map("client_id") @db.Uuid
  employeeCode     String?                  @map("employee_code")
  name             String
  designation      String?
  grade            String?
  phone            String?
  email            String?
  tin              String?
  joiningDate      DateTime?                @map("joining_date") @db.Date
  leavingDate      DateTime?                @map("leaving_date") @db.Date
  isActive         Boolean?                 @default(true) @map("is_active")
  createdAt        DateTime?                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime?                @default(now()) @map("updated_at") @db.Timestamptz(6)
  client           Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salaryStructures PayrollSalaryStructure[]
  runItems         PayrollRunItem[]

  @@unique([clientId, employeeCode])
  @@index([clientId, isActive], map: "idx_payroll_employees_client_active")
  @@map("payroll_employees")
}

model PayrollSalaryStructure {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String          @map("client_id") @db.Uuid
  employeeId    String          @map("employee_id") @db.Uuid
  basic         Decimal?        @default(0) @db.Decimal(15, 2)
  housing       Decimal?        @default(0) @db.Decimal(15, 2)
  medical       Decimal?        @default(0) @db.Decimal(15, 2)
  conveyance    Decimal?        @default(0) @db.Decimal(15, 2)
  employerPf    Decimal?        @default(0) @map("employer_pf") @db.Decimal(15, 2)
  staffPf       Decimal?        @default(0) @map("staff_pf") @db.Decimal(15, 2)
  tax           Decimal?        @default(0) @db.Decimal(15, 2)
  effectiveFrom DateTime?       @default(now()) @map("effective_from") @db.Date
  createdAt     DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?       @default(now()) @map("updated_at") @db.Timestamptz(6)
  client        Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee      PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([clientId, employeeId])
  @@index([clientId], map: "idx_payroll_salary_structures_client")
  @@map("payroll_salary_structures")
}

model PayrollRun {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId         String           @map("client_id") @db.Uuid
  fiscalYearId     String           @map("fiscal_year_id") @db.Uuid
  periodLabel      String           @map("period_label")
  periodStart      DateTime         @map("period_start") @db.Date
  periodEnd        DateTime         @map("period_end") @db.Date
  status           String           @default("draft")
  source           String           @default("manual")
  notes            String?
  accrualVoucherId String?          @map("accrual_voucher_id") @db.Uuid
  paymentVoucherId String?          @map("payment_voucher_id") @db.Uuid
  createdBy        String?          @map("created_by") @db.Uuid
  createdAt        DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  client           Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fiscalYear       FiscalYear       @relation(fields: [fiscalYearId], references: [id])
  accrualVoucher   Voucher?         @relation("PayrollAccrualVoucher", fields: [accrualVoucherId], references: [id])
  paymentVoucher   Voucher?         @relation("PayrollPaymentVoucher", fields: [paymentVoucherId], references: [id])
  items            PayrollRunItem[]

  @@unique([clientId, fiscalYearId, periodLabel])
  @@index([clientId, fiscalYearId], map: "idx_payroll_runs_client_fy")
  @@index([status], map: "idx_payroll_runs_status")
  @@map("payroll_runs")
}

model PayrollRunItem {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollRunId    String                @map("payroll_run_id") @db.Uuid
  employeeId      String?               @map("employee_id") @db.Uuid
  employeeName    String                @map("employee_name")
  designation     String?
  grade           String?
  grossSalary     Decimal?              @default(0) @map("gross_salary") @db.Decimal(15, 2)
  totalAdditions  Decimal?              @default(0) @map("total_additions") @db.Decimal(15, 2)
  totalDeductions Decimal?              @default(0) @map("total_deductions") @db.Decimal(15, 2)
  netPayable      Decimal?              @default(0) @map("net_payable") @db.Decimal(15, 2)
  createdAt       DateTime?             @default(now()) @map("created_at") @db.Timestamptz(6)
  payrollRun      PayrollRun            @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee        PayrollEmployee?      @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  components      PayrollRunComponent[]

  @@index([payrollRunId], map: "idx_payroll_run_items_run")
  @@index([employeeId], map: "idx_payroll_run_items_employee")
  @@map("payroll_run_items")
}

model PayrollRunComponent {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runItemId String         @map("run_item_id") @db.Uuid
  code      String
  label     String
  kind      String
  amount    Decimal?       @default(0) @db.Decimal(15, 2)
  createdAt DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  runItem   PayrollRunItem @relation(fields: [runItemId], references: [id], onDelete: Cascade)

  @@index([runItemId], map: "idx_payroll_run_components_item")
  @@index([code], map: "idx_payroll_run_components_code")
  @@map("payroll_run_components")
}

model PayrollAccountMapping {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String      @map("client_id") @db.Uuid
  componentCode String      @map("component_code")
  accountHeadId String      @map("account_head_id") @db.Uuid
  createdAt     DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?   @default(now()) @map("updated_at") @db.Timestamptz(6)
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  accountHead   AccountHead @relation(fields: [accountHeadId], references: [id])

  @@unique([clientId, componentCode])
  @@index([clientId], map: "idx_payroll_account_mappings_client")
  @@map("payroll_account_mappings")
}

model PayrollPolicy {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String    @map("client_id") @db.Uuid
  housingPercent Decimal?   @default(0) @map("housing_percent") @db.Decimal(5,2)
  medicalPercent Decimal?   @default(0) @map("medical_percent") @db.Decimal(5,2)
  conveyancePercent Decimal? @default(0) @map("conveyance_percent") @db.Decimal(5,2)
  employerPfPercent Decimal? @default(0) @map("employer_pf_percent") @db.Decimal(5,2)
  staffPfPercent Decimal?    @default(0) @map("staff_pf_percent") @db.Decimal(5,2)
  taxPercent     Decimal?   @default(0) @map("tax_percent") @db.Decimal(5,2)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId])
  @@index([clientId], map: "idx_payroll_policies_client")
  @@map("payroll_policies")
}
